# ============================================================================
# MOMOCRI AI School Platform - Environment Variables
# ============================================================================
# Copy this to .env and fill in values for local development.
# For production, set these in Render Dashboard / Vercel Dashboard.
# ============================================================================

# ── Django Core ──────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_ALLOWED_HOSTS=momocri-api.onrender.com,localhost
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_LOG_LEVEL=INFO

# ── CORS / CSRF (frontend URLs) ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://ai-school-platform.vercel.app
CSRF_TRUSTED_ORIGINS=https://ai-school-platform.vercel.app

# ── Database: Neon PostgreSQL ────────────────────────────────────────────────
# Get from: https://console.neon.tech → Connection Details
# Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-example.ap-southeast-1.aws.neon.tech/momocri_db?sslmode=require

# ── Cache/Queue: Upstash Redis ──────────────────────────────────────────────
# Get from: https://console.upstash.com → Redis → Details
# Format: rediss://default:password@endpoint:6379
CELERY_BROKER_URL=rediss://default:your-password@your-endpoint.upstash.io:6379
CELERY_RESULT_BACKEND=rediss://default:your-password@your-endpoint.upstash.io:6379

# ── Storage: Cloudflare R2 ──────────────────────────────────────────────────
# Get from: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_BUCKET_NAME=momocri-media
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_CUSTOM_DOMAIN=media.your-domain.com

# ── AI Coach: Anthropic Claude ─────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Frontend (Vercel env vars) ──────────────────────────────────────────────
# Set these in Vercel Dashboard → Settings → Environment Variables
# NEXT_PUBLIC_API_URL=https://momocri-api.onrender.com/api/v1
